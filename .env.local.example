# ──────────────────────────────────────────────────────────────
# Supabase (Auth + PostgreSQL)
# ──────────────────────────────────────────────────────────────
# Safe to expose to the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY. Never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────
# Cloudflare R2 (S3-compatible object storage)
# SERVER-ONLY. Used by Route Handlers to mint pre-signed URLs.
# These must NEVER be prefixed with NEXT_PUBLIC_.
# ──────────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=

# Public base URL used to read objects back (e.g. R2 public bucket
# or a custom domain / Cloudflare CDN in front of the bucket).
NEXT_PUBLIC_R2_PUBLIC_URL=

# ──────────────────────────────────────────────────────────────
# Web Push (D-Day / anniversary reminders)
# Generate a key pair with:  npx web-push generate-vapid-keys
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Secret that protects the daily reminder cron route. Set the same value in
# Vercel; Vercel Cron automatically sends it as a Bearer token.
CRON_SECRET=
